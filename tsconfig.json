{
    "compilerOptions": {
        "target": "es2023",
        "types": ["node", "@types/openui5"],
        "skipLibCheck": true,
        "allowJs": true,
        "strictPropertyInitialization": false,
        "rootDir": "./webapp",
        "paths": {
            "ui5/walkthrough/*": ["./webapp/*"]
        }
    },
    "include": ["./webapp/**/*"]
}
